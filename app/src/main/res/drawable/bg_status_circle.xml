<!-- res/drawable/bg_status_circle.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#FFFFFF" />
    <stroke
        android:width="6dp">
        <gradient
            android:startColor="#81C784"
            android:endColor="#4CAF50"
            android:type="sweep"
            android:centerX="0.5"
            android:centerY="0.5"/>
    </stroke>
    <size
        android:width="180dp"
        android:height="180dp" />
</shape>
