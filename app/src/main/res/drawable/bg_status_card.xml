<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 背景色：纯白色或极浅的灰绿色 -->
    <solid android:color="#FFFFFF" />

    <!-- 圆角 -->
    <corners android:radius="12dp" />

    <!-- 可选：添加一个非常细、非常浅的绿色边框，增加精致感 -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" /> <!-- 非常浅的灰色边框，也可以用 #D4E1D4 (浅绿灰) -->

    <!-- 可选：添加内阴影/内发光效果，模拟轻微的凸起感 -->
    <!-- 注意：Android Shape 不直接支持内阴影，可以用 layer-list 模拟 -->
</shape>