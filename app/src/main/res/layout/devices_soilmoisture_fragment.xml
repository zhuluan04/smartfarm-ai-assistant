<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_soil"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 顶部导航栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#2196F3" />

            <TextView
                android:id="@+id/detailTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="土壤湿度监测"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2d5a3d"
                android:layout_marginStart="12dp" />

            <ImageView
                android:id="@+id/refreshButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_refresh"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#2196F3" />

        </LinearLayout>

        <!-- 主数据显示卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 水滴动画区域 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginBottom="16dp">

                    <!-- 水波纹效果 -->
                    <View
                        android:id="@+id/waveEffect1"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/wave_circle_large"
                        android:alpha="0.2" />

                    <View
                        android:id="@+id/waveEffect2"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/wave_circle_medium"
                        android:alpha="0.3" />

                    <View
                        android:id="@+id/waveEffect3"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/wave_circle_small"
                        android:alpha="0.4" />

                    <!-- 水滴容器 -->
                    <ImageView
                        android:id="@+id/dropletContainer"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_water_droplet"
                        app:tint="#2196F3" />

                    <!-- 水位填充效果 -->
                    <View
                        android:id="@+id/waterLevel"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:layout_centerInParent="true"
                        android:layout_marginTop="30dp"
                        android:background="@drawable/bg_water_fill"
                        android:alpha="0.6" />

                </RelativeLayout>

                <!-- 当前湿度值 -->
                <TextView
                    android:id="@+id/currentValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="45"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"
                    android:gravity="center"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="% 土壤含水量"
                    android:textSize="18sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- 状态标签 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="湿度适宜"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"
                        android:background="@drawable/bg_status_tag_green"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:drawableStart="@drawable/ic_check_circle"
                        android:drawablePadding="6dp" />

                </LinearLayout>

                <!-- 传感器状态 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_sensor_status">

                    <View
                        android:id="@+id/statusIndicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_shape"
                        android:backgroundTint="#4CAF50" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="传感器在线"
                        android:textSize="13sp"
                        android:textColor="#6b7280"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/lastUpdateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="实时监测"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 湿度等级指示器 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="土壤湿度等级"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2d5a3d"
                    android:layout_marginBottom="16dp" />

                <!-- 湿度进度条 -->
                <RelativeLayout
                    android:id="@+id/moistureBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_moisture_bar" />

                    <ImageView
                        android:id="@+id/moistureIndicator"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_water_droplet"
                        android:layout_centerVertical="true"
                        app:tint="#2196F3" />

                </RelativeLayout>

                <!-- 等级标签 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="干燥"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E"
                        android:gravity="start" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="偏干"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="适宜"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="过湿"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E"
                        android:gravity="end" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

                <!-- 参考值表格 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:background="@drawable/bg_table_row">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🏜️ 干燥"
                            android:textSize="14sp"
                            android:textColor="#6b7280" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&lt; 20%"
                            android:textSize="14sp"
                            android:textColor="#9E9E9E" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌾 偏干"
                            android:textSize="14sp"
                            android:textColor="#6b7280" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20% - 40%"
                            android:textSize="14sp"
                            android:textColor="#9E9E9E" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:background="@drawable/bg_table_row">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="💧 适宜"
                            android:textSize="14sp"
                            android:textColor="#6b7280"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="40% - 70%"
                            android:textSize="14sp"
                            android:textColor="#2196F3"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="💦 偏湿"
                            android:textSize="14sp"
                            android:textColor="#6b7280" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="70% - 85%"
                            android:textSize="14sp"
                            android:textColor="#9E9E9E" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:background="@drawable/bg_table_row">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌊 过湿"
                            android:textSize="14sp"
                            android:textColor="#6b7280" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&gt; 85%"
                            android:textSize="14sp"
                            android:textColor="#9E9E9E" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 灌溉建议 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_water_pump"
                        android:layout_marginEnd="8dp"
                        app:tint="#2196F3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="灌溉建议"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2d5a3d" />

                </LinearLayout>

                <TextView
                    android:id="@+id/descriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="当前土壤湿度适中，水分充足。植物根系可以正常吸收水分和养分，暂时无需灌溉。"
                    android:textSize="15sp"
                    android:textColor="#6b7280"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

                <!-- 灌溉计划 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_irrigation_plan"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="下次建议灌溉时间"
                        android:textSize="13sp"
                        android:textColor="#6b7280"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_schedule"
                            android:layout_marginEnd="12dp"
                            app:tint="#2196F3" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/nextIrrigationTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24小时后"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#2196F3"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/nextIrrigationDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="明天 14:30"
                                android:textSize="13sp"
                                android:textColor="#9E9E9E" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/irrigationAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2L/m²"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2d5a3d"
                            android:background="@drawable/bg_amount_tag"
                            android:padding="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 适宜作物推荐 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_eco"
                        android:layout_marginEnd="8dp"
                        app:tint="#4CAF50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="适宜种植作物"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2d5a3d" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="当前湿度条件："
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2d5a3d"
                    android:layout_marginBottom="8dp" />

                <!-- 作物标签 -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/cropChipContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="center"
                    app:justifyContent="flex_start">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥬 叶菜类"
                        android:textSize="14sp"
                        android:textColor="#2d5a3d"
                        android:background="@drawable/bg_chip_plant"
                        android:padding="8dp"
                        android:layout_margin="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍅 番茄"
                        android:textSize="14sp"
                        android:textColor="#2d5a3d"
                        android:background="@drawable/bg_chip_plant"
                        android:padding="8dp"
                        android:layout_margin="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥒 黄瓜"
                        android:textSize="14sp"
                        android:textColor="#2d5a3d"
                        android:background="@drawable/bg_chip_plant"
                        android:padding="8dp"
                        android:layout_margin="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌽 玉米"
                        android:textSize="14sp"
                        android:textColor="#2d5a3d"
                        android:background="@drawable/bg_chip_plant"
                        android:padding="8dp"
                        android:layout_margin="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥕 胡萝卜"
                        android:textSize="14sp"
                        android:textColor="#2d5a3d"
                        android:background="@drawable/bg_chip_plant"
                        android:padding="8dp"
                        android:layout_margin="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌶️ 辣椒"
                        android:textSize="14sp"
                        android:textColor="#2d5a3d"
                        android:background="@drawable/bg_chip_plant"
                        android:padding="8dp"
                        android:layout_margin="4dp" />

                </com.google.android.flexbox.FlexboxLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 快速操作 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="快速操作"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/historyCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_history"
                        android:layout_marginBottom="8dp"
                        app:tint="#2196F3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="历史数据"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#2d5a3d" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/settingsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_settings"
                        android:layout_marginBottom="8dp"
                        app:tint="#2196F3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="传感器设置"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#2d5a3d" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- 更多功能 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/irrigationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_water_pump"
                    android:layout_marginEnd="12dp"
                    app:tint="#2196F3" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="智能灌溉控制"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2d5a3d" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#9E9E9E" />

            </LinearLayout>

