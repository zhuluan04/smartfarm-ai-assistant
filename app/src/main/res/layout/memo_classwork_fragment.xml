<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- AppBarLayout - 可折叠的顶部区域 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:contentScrim="@android:color/transparent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:titleEnabled="false">

            <!-- 可折叠的内容区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7">

                <!-- 顶部卡片区域 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/header_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradient_header_bg"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- 标题图标 -->
                        <ImageView
                            android:id="@+id/header_icon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_memo"
                            android:tint="#FFFFFF"
                            tools:ignore="UseAppTint" />

                        <!-- 标题文字 -->
                        <TextView
                            android:id="@+id/header_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="智能备忘录"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <!-- 副标题 -->
                        <TextView
                            android:id="@+id/header_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="8dp"
                            android:alpha="0.9"
                            android:fontFamily="sans-serif-light"
                            android:lineSpacingExtra="2dp"
                            android:text="AI助手帮你记录生活"
                            android:textAlignment="center"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 搜索和筛选卡片 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/search_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- 搜索栏 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/search_bg"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="16dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_search"
                                app:tint="#6C63FF" />

                            <EditText
                                android:id="@+id/edit_search"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="搜索备忘录..."
                                android:inputType="text"
                                android:textColor="#2C3E50"
                                android:textColorHint="#95A5A6"
                                android:textSize="15sp" />

                            <ImageView
                                android:id="@+id/btn_voice_search"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:src="@drawable/ic_mic"
                                app:tint="#6C63FF" />

                        </LinearLayout>

                        <!-- 快捷筛选标签 -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:scrollbars="none">

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/chip_group_filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:singleSelection="true">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_all"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checked="true"
                                    android:text="全部"
                                    android:textColor="@color/chip_text_color"
                                    app:chipBackgroundColor="@color/chip_bg_color"
                                    app:chipStrokeWidth="0dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_important"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="重要"
                                    android:textColor="@color/chip_text_color"
                                    app:chipBackgroundColor="@color/chip_bg_color"
                                    app:chipIcon="@drawable/ic_star"
                                    app:chipStrokeWidth="0dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_today"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="今天"
                                    android:textColor="@color/chip_text_color"
                                    app:chipBackgroundColor="@color/chip_bg_color"
                                    app:chipIcon="@drawable/ic_today"
                                    app:chipStrokeWidth="0dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_image"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="有图片"
                                    android:textColor="@color/chip_text_color"
                                    app:chipBackgroundColor="@color/chip_bg_color"
                                    app:chipIcon="@drawable/ic_image"
                                    app:chipStrokeWidth="0dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_ai"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AI生成"
                                    android:textColor="@color/chip_text_color"
                                    app:chipBackgroundColor="@color/chip_bg_color"
                                    app:chipIcon="@drawable/ic_ai_sparkles"
                                    app:chipStrokeWidth="0dp" />

                            </com.google.android.material.chip.ChipGroup>

                        </HorizontalScrollView>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- AI功能快捷入口 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/ai_features_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_ai_sparkles"
                            android:drawablePadding="8dp"
                            android:drawableTint="#6C63FF"
                            android:fontFamily="sans-serif-medium"
                            android:text="AI 智能助手"
                            android:textColor="#2C3E50"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <!-- AI智能分类 -->
                            <LinearLayout
                                android:id="@+id/btn_ai_classify"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/ai_feature_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_auto_awesome"
                                    app:tint="#6C63FF" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="智能分类"
                                    android:textColor="#2C3E50"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <!-- AI语音输入 -->
                            <LinearLayout
                                android:id="@+id/btn_ai_voice"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/ai_feature_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_keyboard_voice"
                                    app:tint="#FF6B6B" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="语音记录"
                                    android:textColor="#2C3E50"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <!-- AI图片识别 -->
                            <LinearLayout
                                android:id="@+id/btn_ai_ocr"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/ai_feature_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_image_search"
                                    app:tint="#4ECDC4" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="图片识别"
                                    android:textColor="#2C3E50"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <!-- AI智能提醒 -->
                            <LinearLayout
                                android:id="@+id/btn_ai_reminder"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/ai_feature_bg"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_notifications_active"
                                    app:tint="#FFD93D" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="智能提醒"
                                    android:textColor="#2C3E50"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 添加按钮组 -->
                <LinearLayout
                    android:id="@+id/button_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                        android:id="@+id/button_add"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="新建备忘"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#6C63FF"
                        app:elevation="6dp"
                        app:icon="@drawable/ic_add"
                        app:iconTint="#FFFFFF" />

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/button_sort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        app:backgroundTint="#FFFFFF"
                        app:elevation="6dp"
                        app:fabSize="normal"
                        app:srcCompat="@drawable/ic_sort"
                        app:tint="#6C63FF" />

                </LinearLayout>

            </LinearLayout>

            <!-- 固定在顶部的工具栏 - 折叠后显示 -->
            <LinearLayout
                android:id="@+id/toolbar_collapsed"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@drawable/gradient_header_bg"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layout_collapseMode="pin">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_memo"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="智能备忘录"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btn_expand"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@drawable/ic_expand_more"
                    app:tint="#FFFFFF" />

            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 备忘录列表区域 - 使用NestedScrollView支持协调滚动 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 列表标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FAFBFC"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="全部备忘"
                        android:textColor="#2C3E50"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/memo_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/count_badge_bg"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="0"
                        android:textColor="#6C63FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btn_view_mode"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:src="@drawable/ic_view_module"
                        app:tint="#6C63FF" />

                </LinearLayout>

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8EAED" />

                <!-- 备忘录列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recy_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:padding="12dp"
                    android:scrollbars="vertical" />

                <!-- 空状态视图 -->
                <LinearLayout
                    android:id="@+id/empty_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="400dp"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:alpha="0.3"
                        android:src="@drawable/ic_empty_memo"
                        app:tint="#95A5A6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="还没有备忘录"
                        android:textColor="#95A5A6"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="点击上方按钮创建第一条备忘"
                        android:textColor="#BDC3C7"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.core.widget.NestedScrollView>

    <!-- 快速返回顶部按钮 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_scroll_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:visibility="gone"
        app:backgroundTint="#6C63FF"
        app:srcCompat="@drawable/ic_arrow_upward"
        app:tint="#FFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>