<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_plant_growth"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="80dp">

        <!-- 植物标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱 植物生长监测"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"
            android:shadowColor="#44000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"/>

        <!-- 植物卡片（3D效果） -->
        <androidx.cardview.widget.CardView
            android:id="@+id/plantCard"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardMaxElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/card_gradient_plant">

                <ImageView
                    android:id="@+id/plantImage"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_plant"
                    android:alpha="0.9"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/card_bottom_gradient">

                    <TextView
                        android:id="@+id/plantName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿 绿萝"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"/>

                    <TextView
                        android:id="@+id/plantType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="攀缘植物 | 常绿观叶"
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:alpha="0.9"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 生长进度条 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📈 生长进度"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>

                    <TextView
                        android:id="@+id/growthPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="40%"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/holo_green_dark"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/growthProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="12dp"
                    android:progress="40"
                    android:max="100"
                    android:progressTint="@android:color/holo_green_dark"
                    android:background="@drawable/progress_bg_plant"
                    android:indeterminate="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 生长信息卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/infoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 生长数据"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 高度信息 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/info_item_bg">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_crop"
                            app:tint="@android:color/holo_green_dark"/>

                        <TextView
                            android:id="@+id/plantHeight"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📏 高度：12.5 cm"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <!-- 叶片数 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/info_item_bg"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@android:color/holo_green_dark"/>

                        <TextView
                            android:id="@+id/plantLeaves"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🍃 叶片数：8 片"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <!-- 土壤湿度 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/info_item_bg"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="@android:color/holo_blue_dark"/>

                        <TextView
                            android:id="@+id/soilMoisture"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="💧 土壤湿度：65%"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <!-- 温度 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/info_item_bg"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            app:tint="@android:color/holo_orange_dark"/>

                        <TextView
                            android:id="@+id/temperature"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌡️ 温度：23℃"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 操作按钮 -->
        <Button
            android:id="@+id/historyButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📊 查看详细生长记录"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_gradient_plant"
            android:elevation="8dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp"/>

        <!-- 小贴士 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 每日浇水，定期施肥，让植物茁壮成长！"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:alpha="0.8"
            android:gravity="center"
            android:padding="12dp"
            android:background="@drawable/tip_bg_plant"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>