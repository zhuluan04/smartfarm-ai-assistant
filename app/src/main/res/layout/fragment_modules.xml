<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:clipToPadding="false"
    android:fillViewport="true">

    <!--    线性布局-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section：修正标题区域圆形装饰对齐 -> 相对布局 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp">

            <!-- 圆形装饰背景：固定大小+居中对齐，避免偏移 -->
            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="-16dp"
                android:alpha="0.15"
                android:background="@drawable/bg_circle_accent"
                android:scaleType="centerCrop" />

            <!-- 主标题：确保居中无偏移 -->
            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:contentDescription="功能中心标题"
                android:elevation="4dp"
                android:fontFamily="sans-serif-medium"
                android:shadowColor="#4D000000"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="6"
                android:text="🌿 功能中心"
                android:textColor="#1B5E20"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- 副标题：基于主标题底部居中，避免错位 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/title"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="12dp"
                android:alpha="0.85"
                android:contentDescription="功能中心副标题"
                android:fontFamily="sans-serif"
                android:text="探索智能植物管理功能"
                android:textColor="#555555"
                android:textSize="16sp" />

        </RelativeLayout>

        <!-- Feature Card Grid：修正卡片内图标对齐 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:columnOrderPreserved="false"
            android:padding="8dp"
            android:useDefaultMargins="false">

            <!-- 1. 生长情况卡片：图标+圆形背景居中对齐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_grow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="生长情况卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#F5FFF5"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/grow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_green"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 图标容器：圆形背景+图标居中，避免歪斜 -->
                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <!-- 圆形背景锚点：固定大小+居中，作为图标背景 -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <!-- 图标：强制居中+不拉伸 -->
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="生长情况图标"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_growth"
                            app:tint="#388E3C" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="生长情况"
                        android:textColor="#1B5E20"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="监测植物健康状态"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. 成长设置卡片：同规则对齐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_foster"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="成长设置卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#F5FAFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/foster"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_blue"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="成长设置图标"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_settings"
                            app:tint="#1976D2" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="成长设置"
                        android:textColor="#1565C0"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="个性化养护方案"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. 植物库卡片：同规则对齐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_botany"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="植物库卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#FAF5FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/botany"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_purple"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="植物库图标"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_library"
                            app:tint="#7B1FA2" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="植物库"
                        android:textColor="#6A1B9A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="丰富的植物百科"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 4. 历史分析卡片：同规则对齐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="历史分析卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#FFF8E1"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_orange"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="历史分析图标"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_history_analysis"
                            app:tint="#EF6C00" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="历史分析"
                        android:textColor="#E65100"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="成长轨迹追踪"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 5. 信息分析卡片：同规则对齐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_analyze"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="信息分析卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#E6FFFB"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/analyze"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_teal"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="信息分析图标"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_analytics"
                            app:tint="#00796B" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="信息分析"
                        android:textColor="#00695C"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="智能数据洞察"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 6. 环境设置卡片：同规则对齐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/environment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="信息分析卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#E6FFFB"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <!--                环境设置-->
                <LinearLayout
                    android:id="@+id/environment_set"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_teal"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="环境设置图表"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_environment"
                            app:tint="#00796B" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="环境设置"
                        android:textColor="#00695C"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="环境设置"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 7. 小程序 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_tools"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="小程序卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#E6FFFB"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/tools_set"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_teal"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="小程序图标"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_analytics"
                            app:tint="#00796B" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="小程序"
                        android:textColor="#00695C"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="便捷小工具合集"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>



            <!-- 6. 敬请期待卡片：同规则对齐 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_wait"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="12dp"
                android:clickable="true"
                android:contentDescription="敬请期待卡片"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#F5F5F5"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/wait"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient_gray"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:alpha="0.2"
                            android:background="@drawable/bg_circle_accent"
                            android:elevation="3dp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="敬请期待图标"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_coming_soon"
                            app:tint="#616161" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="敬请期待"
                        android:textColor="#424242"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="更多功能即将上线"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- Footer：修正底部标语对齐 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:alpha="0.75"
            android:contentDescription="底部标语"
            android:fontFamily="sans-serif"
            android:text="让科技赋能植物成长 🌱"
            android:textColor="#777777"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>