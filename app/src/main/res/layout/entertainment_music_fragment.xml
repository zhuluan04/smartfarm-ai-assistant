<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_music_gradient">

    <!-- 顶部标题栏 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="正在播放"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 唱片容器 -->
    <FrameLayout
        android:id="@+id/album_container"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 唱片背景（黑胶唱片） -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_album_background"
            android:scaleType="centerCrop" />

        <!-- 专辑封面 -->
        <ImageView
            android:id="@+id/iv_album_cover"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_default_album"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_album_circle" />

    </FrameLayout>

    <!-- 唱针 -->
    <ImageView
        android:id="@+id/iv_needle"
        android:layout_width="120dp"
        android:layout_height="180dp"
        android:src="@drawable/ic_needle"
        android:rotation="-25"
        android:layout_marginStart="200dp"
        app:layout_constraintTop_toTopOf="@id/album_container"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 歌曲信息 -->
    <TextView
        android:id="@+id/tv_song_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="歌曲名称"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:maxLines="1"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintTop_toBottomOf="@id/album_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="歌手名称"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_song_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 歌词区域 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_lyrics"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/tv_artist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 进度条区域 -->
    <TextView
        android:id="@+id/tv_current_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:progressTint="#FFDD001B"
        android:thumbTint="#FFDD001B"
        android:progressBackgroundTint="#33FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/tv_current_time"
        app:layout_constraintTop_toTopOf="@id/tv_current_time"
        app:layout_constraintStart_toEndOf="@id/tv_current_time"
        app:layout_constraintEnd_toStartOf="@id/tv_total_time" />

    <TextView
        android:id="@+id/tv_total_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="04:05"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_current_time"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 控制按钮区域 -->
    <LinearLayout
        android:id="@+id/control_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 播放模式 -->
        <ImageView
            android:id="@+id/iv_play_mode"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_repeat"
            android:padding="4dp"
            android:layout_marginEnd="40dp"
            app:tint="#CCFFFFFF" />

        <!-- 上一曲 -->
        <ImageView
            android:id="@+id/iv_previous"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_previous"
            android:padding="4dp"
            android:layout_marginEnd="30dp"
            app:tint="#FFFFFF" />

        <!-- 播放/暂停 -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_play_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_play"
            app:tint="#FFFFFF"
            app:backgroundTint="#FFDD001B"
            app:elevation="6dp"
            app:fabSize="normal" />

        <!-- 下一曲 -->
        <ImageView
            android:id="@+id/iv_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next"
            android:padding="4dp"
            android:layout_marginStart="30dp"
            app:tint="#FFFFFF" />

        <!-- 播放列表 -->
        <ImageView
            android:id="@+id/iv_playlist"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_playlist"
            android:padding="4dp"
            android:layout_marginStart="40dp"
            app:tint="#CCFFFFFF" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>