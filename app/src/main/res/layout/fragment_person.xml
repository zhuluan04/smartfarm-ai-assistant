<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_green_profile">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- 顶部用户信息区域 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/user_info_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            android:backgroundTint="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="36dp"
                android:paddingHorizontal="24dp">

                <!-- 头像容器 -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

<!--                    用户头像-->
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/civ_avatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/ic_person"
                        app:civ_border_width="4dp"
                        app:civ_border_color="#4a8b5c" />

                    <!-- 在线状态指示器 -->
                    <View
                        android:id="@+id/online_indicator"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/circle_green_large"
                        android:elevation="2dp" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="林炜宾"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2d5a3d"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="linjiu@example.com"
                    android:textSize="14sp"
                    android:textColor="#6b7280"
                    android:layout_marginTop="6dp" />

                <!-- 用户等级标签 -->
                <TextView
                    android:id="@+id/tv_user_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌟 农业专家"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_level_tag"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:layout_marginTop="12dp" />

                <!-- 系统状态指标 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:background="@drawable/bg_stats_container"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_devices_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#4a8b5c"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="在线设备"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#E5E7EB"
                        android:layout_marginHorizontal="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_ai_tasks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="28"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FF8F00"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI分析"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#E5E7EB"
                        android:layout_marginHorizontal="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_notifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#F44336"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="待处理"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 系统管理区域 -->
        <TextView
            android:id="@+id/section_system"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 系统管理"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginTop="32dp"
            android:layout_marginStart="28dp"
            app:layout_constraintTop_toBottomOf="@id/user_info_container"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 功能入口区域 -->
        <LinearLayout
            android:id="@+id/system_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/section_system"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 系统状态总览卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_system_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#E8F5E8">

<!--                这里的clickable等会吃掉点击事件...-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:srcCompat="@drawable/ic_dashboard"
                        android:layout_gravity="center_vertical"
                        app:tint="#4a8b5c" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="系统状态总览"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2d5a3d" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设备运行状态、传感器数据统计"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- 状态指示器 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="8dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/circle_green"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正常"
                            android:textSize="10sp"
                            android:textColor="#4CAF50" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        app:tint="#B0B0B0" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 设备管理卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_device_management"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFF3E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:srcCompat="@drawable/ic_sensors"
                        android:layout_gravity="center_vertical"
                        app:tint="#FF8F00" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="传感器设备"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FF8F00" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="温湿度、光照、土壤传感器管理"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/device_status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6台"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_badge_orange"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="8dp"
                        android:layout_gravity="center_vertical" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        app:tint="#B0B0B0" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI模型管理卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ai_management"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#E3F2FD">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:srcCompat="@drawable/ic_ai_model"
                        android:layout_gravity="center_vertical"
                        app:tint="#1976D2" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI模型管理"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1976D2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="植物识别、生长分析模型配置"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/ai_model_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v2.1"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_badge_blue"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="8dp"
                        android:layout_gravity="center_vertical" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        app:tint="#B0B0B0" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 个人设置区域 -->
        <TextView
            android:id="@+id/section_personal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤 个人设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginTop="24dp"
            android:layout_marginStart="28dp"
            app:layout_constraintTop_toBottomOf="@id/system_container"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/personal_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/section_personal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 账户设置卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_account_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:srcCompat="@drawable/ic_account_settings"
                        android:layout_gravity="center_vertical"
                        app:tint="#5F6368" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="账户设置"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="个人信息、密码、通知设置"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        app:tint="#B0B0B0" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 通知设置卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_notification_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:srcCompat="@drawable/ic_notifications"
                        android:layout_gravity="center_vertical"
                        app:tint="#5F6368" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="通知与提醒"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="异常警报、定时提醒设置"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- 通知开关 -->
                    <Switch
                        android:id="@+id/switch_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="8dp"
                        android:checked="true" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 应用信息区域 -->
        <TextView
            android:id="@+id/section_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 应用信息"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginTop="24dp"
            android:layout_marginStart="28dp"
            app:layout_constraintTop_toBottomOf="@id/personal_container"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/app_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/section_app"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 帮助与反馈卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_help"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:srcCompat="@drawable/ic_help"
                        android:layout_gravity="center_vertical"
                        app:tint="#5F6368" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="帮助与反馈"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="使用指南、问题反馈、技术支持"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        app:tint="#B0B0B0" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 关于应用卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:srcCompat="@drawable/ic_info"
                        android:layout_gravity="center_vertical"
                        app:tint="#5F6368" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="关于应用"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="版本信息、开发团队、隐私政策"
                            android:textSize="12sp"
                            android:textColor="#6b7280"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.2.0"
                        android:textSize="12sp"
                        android:textColor="#6b7280"
                        android:layout_marginEnd="8dp"
                        android:layout_gravity="center_vertical" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        app:tint="#B0B0B0" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 退出登录按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
