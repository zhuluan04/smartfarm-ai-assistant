<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="植物环境控制"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_refresh"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="刷新"
                android:textSize="14sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="18dp" />

        </LinearLayout>

        <!-- 传感器数据展示 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前环境数据"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp" />

                <!-- 传感器数据网格 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- 温度 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="温度"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/tv_temperature_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="23.5°C"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FF6B35" />

                    </LinearLayout>

                    <!-- 湿度 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="湿度"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/tv_humidity_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="65.0%"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#4A90E2" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginTop="8dp">

                    <!-- 光照 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="光照"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/tv_light_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="750 lux"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FFD700" />

                    </LinearLayout>

                    <!-- 土壤湿度 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?android:attr/selectableItemBackground"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="土壤湿度"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/tv_soil_moisture_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45.0%"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#7ED321" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 设备控制 - 美化版卡片风格 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备控制"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="16dp" />

                <!-- 使用 GridLayout 实现 2x2 网格布局 -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="false"
                    android:clipToPadding="false">

                    <!-- 水泵 Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_water_pump"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#F5F9FF"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/iv_water_pump"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_water_pump_off"
                                android:layout_marginBottom="8dp"
                                android:contentDescription="水泵图标" />

                            <TextView
                                android:id="@+id/tv_water_pump_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="水泵"
                                android:textSize="14sp"
                                android:textColor="#333333" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 风扇 Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_fan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#F5F9FF"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/iv_fan"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_fan_off"
                                android:layout_marginBottom="8dp"
                                android:contentDescription="风扇图标" />

                            <TextView
                                android:id="@+id/tv_fan_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="风扇"
                                android:textSize="14sp"
                                android:textColor="#333333" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- LED灯 Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_led"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#F5F9FF"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/iv_led"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_led_off"
                                android:layout_marginBottom="8dp"
                                android:contentDescription="LED灯图标" />

                            <TextView
                                android:id="@+id/tv_led_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LED灯"
                                android:textSize="14sp"
                                android:textColor="#333333" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 加热器 Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_heater"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#F5F9FF"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/iv_heater"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_heater_off"
                                android:layout_marginBottom="8dp"
                                android:contentDescription="加热器图标" />

                            <TextView
                                android:id="@+id/tv_heater_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="加热器"
                                android:textSize="14sp"
                                android:textColor="#333333" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 环境参数设定 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="环境参数设定"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="20dp" />

                <!-- 目标温度设定 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="目标温度"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <TextView
                            android:id="@+id/tv_target_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25°C"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FF6B35" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekbar_target_temp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="30"
                        android:progress="15"
                        android:progressTint="#FF6B35"
                        android:thumbTint="#FF6B35" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="10°C"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="40°C"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 目标湿度设定 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="目标湿度"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <TextView
                            android:id="@+id/tv_target_humidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="70%"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#4A90E2" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekbar_target_humidity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="70"
                        android:progressTint="#4A90E2"
                        android:thumbTint="#4A90E2" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 光照强度设定 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="光照强度"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <TextView
                            android:id="@+id/tv_light_intensity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="800 lux"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFD700" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekbar_light_intensity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="#FFD700"
                        android:thumbTint="#FFD700" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0 lux"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1000 lux"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>