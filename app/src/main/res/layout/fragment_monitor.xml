<?xml version="1.0" encoding="utf-8"?>
<!--滑动view-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 顶部状态栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_status_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:elevation="2dp">

            <!-- 系统状态 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/systemStatus"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="系统正常"
                    android:textSize="14sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 传感器在线数量 -->
            <TextView
                android:id="@+id/sensorCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="传感器: 6/6 在线"
                android:textSize="12sp"
                android:textColor="#666666" />

        </LinearLayout>

        <!-- 标题区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="监控中心"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#2d5a3d" />

            <!-- 刷新按钮 -->
            <ImageView
                android:id="@+id/btnRefreshAll"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_refresh"
                android:background="@drawable/bg_circle_button_green_1"
                android:padding="6dp"
                android:contentDescription="刷新所有数据" />

        </LinearLayout>

        <!-- 副标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="智能监测植物生长环境"
            android:textSize="16sp"
            android:textColor="#6b7280"
            android:layout_marginBottom="28dp" />

        <!-- 摄像头预览区域：WebView 显示 ESP32 视频流 (增大高度，接近全屏) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="480dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <WebView
                android:id="@+id/webViewCamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </androidx.cardview.widget.CardView>

        <!-- 环境监测模块 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌡️ 环境监测"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!--        在这个LinearLayout底下有多个CardView-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- 温湿度监测卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/tempHumidityCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#E8F5E8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="160dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_temperature_humidity"
                        android:layout_marginBottom="8dp"
                        app:tint="#4a8b5c" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="环境温湿度"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#2d5a3d" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="实时监测环境状态"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                    <!-- 实时数据显示 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/envTempValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="25°C"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FF6F00"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/envHumidityValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="65%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1976D2"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 光照强度监测卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/lightIntensityCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFF3E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="160dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_light_sensor"
                        android:layout_marginBottom="8dp"
                        app:tint="#FF8F00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="光照强度"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FF8F00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="监测光合作用条件"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                    <!-- 光照数据 -->
                    <TextView
                        android:id="@+id/lightIntensityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15,200 Lux"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FF8F00"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="适宜"
                        android:textSize="10sp"
                        android:textColor="#4CAF50"
                        android:background="@drawable/bg_status_tag_green"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- 土壤管理模块 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 土壤管理"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- 土壤湿度卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/soilMoistureCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#E3F2FD">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="160dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_soil_moisture"
                        android:layout_marginBottom="8dp"
                        app:tint="#1976D2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="土壤湿度"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="监测土壤水分含量"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                    <!-- 土壤湿度值 -->
                    <TextView
                        android:id="@+id/soilMoistureValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="42%"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2"
                        android:layout_marginTop="8dp" />

                    <!-- 湿度进度条 -->
                    <ProgressBar
                        android:id="@+id/soilMoistureProgress"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:max="100"
                        android:progress="42"
                        android:progressTint="#1976D2" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 土壤养分卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/nutrientsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#F3E5F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="160dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_nutrients"
                        android:layout_marginBottom="8dp"
                        app:tint="#7B1FA2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="土壤养分"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#7B1FA2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NPK含量检测"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                    <!-- 养分状态 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="N: 中"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#7B1FA2"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="P: 低"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#FF5722"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="K: 高"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- AI分析模块 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 AI智能分析"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- 植物生长分析卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/plantGrowthCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#E8F5E8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="180dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_plant_analysis"
                        android:layout_marginBottom="8dp"
                        app:tint="#2E7D32" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="植物生长分析"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI视觉分析生长状态"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                    <!-- 生长状态 -->
                    <TextView
                        android:id="@+id/growthStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="健康生长"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status_tag_green"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp" />

                    <!-- 生长评分 -->
                    <TextView
                        android:id="@+id/growthScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="评分: 85/100"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 病虫害检测卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/pestDetectionCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFF8E1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="180dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_pest_detection"
                        android:layout_marginBottom="8dp"
                        app:tint="#F57C00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="病虫害检测"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F57C00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="智能识别植物病害"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                    <!-- 检测状态 -->
                    <TextView
                        android:id="@+id/pestStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未发现异常"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status_tag_green"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp" />

                    <!-- 最后检测时间 -->
                    <TextView
                        android:id="@+id/lastScanTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2小时前检测"
                        android:textSize="10sp"
                        android:textColor="#666666"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- 系统管理模块 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ 系统管理"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2d5a3d"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- 数据分析卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDataAnalysis"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFF3E0"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="140dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_analytics"
                        android:layout_marginBottom="8dp"
                        app:tint="#FF8F00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="数据分析"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FF8F00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="历史趋势分析"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 系统设置卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSystemSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#E3F2FD"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="140dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_settings_system"
                        android:layout_marginBottom="8dp"
                        app:tint="#1976D2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="系统设置"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="个性化配置方案"
                        android:textSize="11sp"
                        android:textColor="#6b7280"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- 快捷操作按钮组 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 快捷操作"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2d5a3d"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 开始监测 -->
                    <Button
                        android:id="@+id/btnStartMonitoring"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="开始监测"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        android:drawableStart="@drawable/ic_play"
                        android:drawablePadding="8dp"
                        app:cornerRadius="12dp" />

                    <!-- 导出报告 -->
                    <Button
                        android:id="@+id/btnExportReport"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="导出报告"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:drawableStart="@drawable/ic_download"
                        android:drawablePadding="8dp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </LinearLayout>

