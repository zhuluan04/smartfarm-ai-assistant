<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#cccc">

    <!-- 主角血条，固定在屏幕左上角 -->
    <ProgressBar
        android:id="@+id/hp_mario"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="12dp"
        android:max="100"
        android:progress="100"
        android:progressTint="#FF0000"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 哥布林血条 -->
    <ProgressBar
        android:id="@+id/hp_goblin"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="106dp"
        android:layout_height="8dp"
        android:max="100"
        android:progress="100"
        android:progressTint="#FF0000"
        android:layout_marginBottom="4dp"
        app:layout_constraintStart_toStartOf="@+id/iv_goblin"
        app:layout_constraintBottom_toTopOf="@+id/iv_goblin"/>

    <!-- 静音键-->
    <ImageButton
        android:id="@+id/btn_mute"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:layout_marginTop="140dp"
        android:layout_marginEnd="224dp"
        android:contentDescription="mute"
        android:src="@drawable/ic_volume_on"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 👤 主角马里奥图片 -->
    <ImageView
        android:id="@+id/iv_mario"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/mario_stand"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="200dp"
        android:layout_marginStart="100dp" />

    <!-- 👹 哥布林 -->
    <ImageView
        android:id="@+id/iv_goblin"
        android:layout_width="106dp"
        android:layout_height="97dp"
        android:layout_marginStart="244dp"
        android:layout_marginTop="100dp"
        android:scaleType="centerInside"
        android:src="@drawable/goblin_stand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 左下角方向控制摇杆（自定义控件） -->
    <com.linjiu.recognize.layout.program.game.mario.JoystickView
        android:id="@+id/joystick"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 右下角攻击按钮 -->
    <ImageButton
        android:id="@+id/btn_attack"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_margin="24dp"
        android:background="@drawable/btn_attack_bg"
        android:contentDescription="attack"
        android:scaleType="centerInside"
        android:src="@drawable/ic_attack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ⚡ 特殊技能按钮 -->
    <ImageButton
        android:id="@+id/btn_special"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="150dp"
        android:layout_marginEnd="40dp"
        android:background="@drawable/btn_special"
        android:contentDescription="special"
        android:src="@drawable/ic_combo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🏃 冲刺按钮 -->
    <ImageButton
        android:id="@+id/btn_dash"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="40dp"
        android:layout_marginEnd="140dp"
        android:background="@drawable/btn_dash"
        android:contentDescription="dash"
        android:src="@drawable/ic_level"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🪙 分数 -->
    <TextView
        android:id="@+id/tv_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Score: 0"
        android:textColor="#000"
        android:textSize="16sp"
        android:drawableStart="@drawable/ic_score"
        android:layout_marginTop="16dp"
        android:layout_marginStart="160dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/hp_mario"/>

    <!-- 🏁 游戏等级 -->
    <TextView
        android:id="@+id/tv_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Level: 1"
        android:textColor="#000"
        android:textSize="16sp"
        android:drawableStart="@drawable/ic_level"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_score"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 👤 角色等级 -->
    <TextView
        android:id="@+id/tv_player_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lv. 1"
        android:textColor="#000"
        android:textSize="16sp"
        android:drawableStart="@drawable/ic_player_level"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_level"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 🔵 经验条 -->
    <ProgressBar
        android:id="@+id/tv_exp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="200dp"
        android:layout_height="10dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/exp_bar_fg"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_player_level"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 🔥 连击 -->
    <TextView
        android:id="@+id/tv_combo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Combo x0"
        android:textColor="#FF5722"
        android:textSize="18sp"
        android:drawableStart="@drawable/ic_combo"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_exp"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- ⏱️ 计时器 -->
    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#000"
        android:textSize="18sp"
        android:drawableStart="@drawable/ic_timer"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
